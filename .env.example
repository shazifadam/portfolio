# Sanity — required for Studio (/studio) and content fetches
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_READ_TOKEN=

# Resend — contact form (POST /api/contact)
RESEND_API_KEY=
CONTACT_TO_EMAIL=hussain.shaxif002@gmail.com
# Sender displayed on the email. Until shazifadam.com is verified in
# Resend, set this to "onboarding@resend.dev" (Resend's shared sandbox
# sender). Once the domain is verified, switch to "hello@shazifadam.com"
# (or whatever address you set up) and you'll start sending from your
# own domain. Format: optional name, then <email> in angle brackets:
#   "Shazif Adam <hello@shazifadam.com>"
RESEND_FROM_EMAIL=onboarding@resend.dev

# Plausible — analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=shazifadam.com
